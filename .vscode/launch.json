    "version": "0.2.0",
    "configurations": [
        {
            "name": "flash-logic-analyzer",
            "type": "debugpy",
            "request": "launch",
            "module": "testbed_cb_jtag_probe.scripts.testbed_cb_jtag_probe",
            "cwd": "${workspaceFolder}",
            "args": [
                "flash-logic-analyzer",
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
        },
        {
            "name": "flash-jtag",
            "type": "debugpy",
            "request": "launch",
            "module": "testbed_cb_jtag_probe.scripts.testbed_cb_jtag_probe",
            "cwd": "${workspaceFolder}",
            "args": [
                "flash-jtag",
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
        },
        {
            "name": "download-sigrok",
            "type": "debugpy",
            "request": "launch",
            "module": "testbed_cb_jtag_probe.scripts.testbed_cb_jtag_probe",
            "cwd": "${workspaceFolder}",
            "args": [
                "download-sigrok",
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
        },
        {
            "name": "pytest: test_sigrok_pico.py::test_ok",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "args": [
                "tests/cb_jtag_probe/test_sigrok_pico.py::test_ok",
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
        },
        {
            "name": "pytest",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
        },
        {
            "name": "Python: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}",
            "justMyCode": false,
        }
    ]
}